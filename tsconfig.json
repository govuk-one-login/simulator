{
  "compilerOptions": {
    "module": "ESNext",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "target": "ESNext",
    "noImplicitAny": true,
    "moduleResolution": "bundler",
    "strict": true,
    "sourceMap": true,
    "outDir": "dist",
    "baseUrl": ".",
    "typeRoots": ["@types", "node_modules/@types", "node_modules"],
    "types": ["node", "vitest/globals"],
    "noEmit": true,
    "allowImportingTsExtensions": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["tests", "coverage"]
}
